# ============================================================
# AiNet — Environment Variables
# Copy this file to .env.local and fill in the values
# ============================================================

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# OpenAI (used by the proxy endpoint)
OPENAI_API_KEY=sk-proj-...

# App URL (production URL on Vercel, or ngrok for local dev)
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# LiveKit Cloud (livekit.io)
LIVEKIT_URL=wss://your-app.livekit.cloud
LIVEKIT_API_KEY=your-livekit-api-key
LIVEKIT_API_SECRET=your-livekit-api-secret
LIVEKIT_SIP_DOMAIN=your-sip-domain.sip.livekit.cloud

# Twilio
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_SIP_DOMAIN=your-domain.sip.twilio.com

# Deepgram
DEEPGRAM_API_KEY=your-deepgram-api-key

# Webhook secret (any random string for security)
VOICE_WEBHOOK_SECRET=your-random-secret
